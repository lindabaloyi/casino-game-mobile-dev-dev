# Network Configuration - Auto-detect Mode
# The app will automatically detect the best server URL

# Enable auto-detection (scans for server on network)
EXPO_PUBLIC_AUTODETECT_ENABLED=true

# Local URL (used on desktop - same machine as server)
EXPO_PUBLIC_SOCKET_URL_LOCAL=http://localhost:3001

# LAN URL (used on mobile devices - your computer's local IP)
# IMPORTANT: Replace 192.168.18.14 with your actual local IP address
# To find your IP: run 'ipconfig' on Windows or 'ifconfig' on Mac/Linux
EXPO_PUBLIC_SOCKET_URL_LAN=http://192.168.18.14:3001

# Default fallback (used if auto-detection fails)
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001
