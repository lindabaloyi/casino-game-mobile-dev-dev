# Network Configuration - Auto-detect Mode
# The app will automatically detect the best server URL

# Enable auto-detection (scans for server on network)
AUTODETECT_ENABLED=true

# For Real Device Testing: Set your friend's LAN IP here
# Example: SOCKET_URL_LAN=http://192.168.1.100:3001
SOCKET_URL_LAN=http://192.168.1.100:3001

# Default fallback
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001
