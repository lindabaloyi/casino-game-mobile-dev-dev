{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Expo Web (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8081/multiplayer",  // ← exact path
            "webRoot": "${workspaceFolder}",
            "sourceMapPathOverrides": {
                "webpack:///./*": "${workspaceFolder}/*"
            }
        },
        {
            "name": "Debug Server",
            "cwd": "${workspaceFolder}",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/multiplayer/server/index.js",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"],
            "env": { 
                "NODE_ENV": "development",
                "PORT": "3001"
            }
        }
    ],
    "compounds": [
        {
            "name": "Debug Web & Server",
            "configurations": ["Debug Expo Web (Chrome)", "Debug Server"],
            "stopAll": true
        }
    ]
}